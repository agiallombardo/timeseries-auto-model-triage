# Copy to .env and adjust. .env is gitignored.
# Precedence: code defaults < .env < CLI

# Data (optional; if set, you can run: python main.py)
# DATA_FILE=data/samples/retail_sales_daily.csv
# TIME_COL=date
# DATA_COL=sales
# DATE_FORMAT=

# Performance
# N_RUNS=3
# MODELS=all
# JOBS=1
# TUNE_TOP=3
# TUNE_ALL=false
# OUTPUT_DIR=results

# Optional: fast tuning (fewer grid points / CV splits)
# TUNING_FAST=false
# TUNING_N_SPLITS=3

# Optional: deep learning (epochs / early stopping patience)
# DL_EPOCHS_GRID=50
# DL_EPOCHS_REFIT=200
# DL_PATIENCE=10

# Optional: minimal output (skip extra charts)
# MINIMAL_OUTPUT=false
# NO_CHARTS=false

# Optional: TensorFlow threading
# TF_NUM_INTRAOP_THREADS=
# TF_NUM_INTEROP_THREADS=

# Optional: losses filter (comma-separated; leave unset for all)
# LOSSES=l1,l2
